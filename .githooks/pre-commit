#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PYTHON="$REPO_ROOT/.venv/bin/python"

if [[ ! -x "$PYTHON" ]]; then
  echo "Missing local Python environment: $PYTHON" >&2
  echo "Run: /home/dev_scripts/.local/bin/uv venv --python 3.14.5 .venv && /home/dev_scripts/.local/bin/uv pip install --python .venv/bin/python -e '.[dev]' pip" >&2
  exit 1
fi

echo "Running Ruff..."
"$PYTHON" -m ruff check src tests

echo "Running MyPy..."
"$PYTHON" -m mypy

echo "Running tests..."
"$PYTHON" -m pytest -q
