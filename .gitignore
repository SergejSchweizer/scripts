# Ignore everything by default.
*

# Allow only repository source, tests, scripts, hooks, and core metadata.
!.gitignore
!.github/
!.github/workflows/
!.github/workflows/*.yml
!.githooks/
!.githooks/pre-commit
!README.md
!AGENT.md
!AGENTS.md
!pyproject.toml
!cron/
!cron/**
!src/
!src/**
!tests/
!tests/**
!scripts/
!scripts/**

# Re-ignore generated or local artifacts under allowed paths.
**/__pycache__/
**/*.py[cod]
**/*.pyd
.python-version
.venv/
venv/
env/
ENV/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.nox/
dist/
build/
*.egg-info/
.coverage
*.log
*.tmp
*.temp
.env
.env.*
!.env.example
.idea/
.vscode/
.codex
.codex*
.agents/
.codex-plugin/
*~
*.swp
*.swo
node_modules/
.npm/
.pnpm-store/
